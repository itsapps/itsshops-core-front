{
  "name": "@itsapps/itsshops-core-front",
  "version": "1.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "import": "./dist/core.js"
    },
    "./functions/preview": {
      "types": "./dist/preview.d.ts",
      "import": "./dist/preview.js"
    },
    "./scripts": {
      "import": "./dist/scripts/index.ts"
    }
  },
  "files": [
    "bin/",
    "dist/",
    "assets/",
    "templates/"
  ],
  "bin": {
    "itsshops": "./dist/itsshops.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch & node scripts/watch-templates.mjs",
    "prepare": "npm run build"
  },
  "simple-git-hooks": {
    "pre-commit": "npm run build"
  },
  "dependencies": {
    "@11ty/eleventy": "^3.1.2",
    "@11ty/eleventy-img": "^6.0.4",
    "@iarna/toml": "^2.2.5",
    "@netlify/functions": "5.0.0",
    "@portabletext/to-html": "^5.0.2",
    "@sanity/client": "^7.14.1",
    "@sanity/image-url": "^2.0.3",
    "@sindresorhus/slugify": "^3.0.0",
    "autoprefixer": "^10.4.27",
    "commander": "^14.0.2",
    "countries-list": "^3.3.0",
    "cssnano": "^7.1.3",
    "daisyui": "^5.5.18",
    "dayjs": "^1.11.19",
    "debug": "^4.4.3",
    "embla-carousel": "^8.6.0",
    "embla-carousel-autoplay": "^8.6.0",
    "esbuild": "^0.27.3",
    "fs-extra": "^11.3.3",
    "i18n-iso-countries": "^7.14.0",
    "i18next": "^25.8.18",
    "lodash": "^4.17.23",
    "nunjucks": "^3.2.4",
    "postcss": "^8.5.8",
    "postcss-cli": "11.0.0",
    "postcss-custom-media": "^12.0.1",
    "postcss-import": "^16.1.1",
    "postcss-import-ext-glob": "^2.1.1",
    "postcss-js": "^5.0.3",
    "postcss-load-config": "6.0.1",
    "postcss-nesting": "^13.0.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@types/11ty__eleventy-img": "^4.0.0",
    "@types/fs-extra": "^11.0.4",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.0.9",
    "@types/nunjucks": "^3.2.6",
    "@types/postcss-import": "^14.0.3",
    "11ty.ts": "^0.0.7",
    "simple-git-hooks": "^2.13.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
