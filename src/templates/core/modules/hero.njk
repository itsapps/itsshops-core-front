{% if _isFirstModule and module.bgImage %}
  {%- html "preloads" -%}
  <link rel="preload" as="image" href="{{ module.bgImage | imageUrl(1600) }}">
  {%- endhtml -%}
{% endif %}
<div class="hero">
  {% if module.bgImage %}
    <figure class="hero-image">
      {% if _isFirstModule %}
        {% sanityPicture module.bgImage, imageSizes.hero, { loading: "eager", fetchpriority: "high" } %}
      {% else %}
        {% sanityPicture module.bgImage, imageSizes.hero %}
      {% endif %}
    </figure>
  {% endif %}
  {% if module.title %}
    <h2 class="hero-heading">{{ module.title | localize(_locale, defaultLocale) }}</h2>
  {% endif %}
</div>
