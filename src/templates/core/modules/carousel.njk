{% if _isFirstModule and module.slides.length %}
  {%- html "preloads" -%}
  <link rel="preload" as="image" href="{{ module.slides[0] | imageUrl(1200) }}">
  {%- endhtml -%}
{% endif %}
<div class="carousel" data-autoplay="{{ module.autoplay }}" data-loop="{{ module.loop }}" data-fade="{{ module.fade }}"{% if module.autoplay %} data-delay="{{ module.autoplayDelay }}"{% endif %}>
  {% for slide in module.slides %}
    <figure class="carousel-slide">
      {% if loop.first and _isFirstModule %}
        {% sanityPicture slide, imageSizes.carousel, { loading: "eager", fetchpriority: "high" } %}
      {% else %}
        {% sanityPicture slide, imageSizes.carousel %}
      {% endif %}
    </figure>
  {% endfor %}
</div>
