{%- set _locale   = page.lang or coreConfig.defaultLocale -%}
{%- set _settings = cms[_locale].settings -%}
{%- if coreConfig.manifest.colorScheme == 'light dark' -%}
<meta name="theme-color" media="(prefers-color-scheme: light)" content="{{ coreConfig.manifest.themeBgColor }}" />
<meta name="theme-color" media="(prefers-color-scheme: dark)" content="{{ coreConfig.manifest.themeColor }}" />
<meta name="color-scheme" content="light dark" />
{%- elif coreConfig.manifest.colorScheme == 'dark' -%}
<meta name="theme-color" content="{{ coreConfig.manifest.themeColor }}" />
<meta name="color-scheme" content="dark" />
{%- else -%}
<meta name="theme-color" content="{{ coreConfig.manifest.themeBgColor }}" />
<meta name="color-scheme" content="light" />
{%- endif %}
<meta name="apple-mobile-web-app-title" content="{{ (_settings.siteTitle | stegaClean) or '' }}" />
<link rel="icon" type="image/png" href={{ '/favicon-96x96.png' | url }} sizes="96x96" />
<link rel="icon" type="image/svg+xml" href={{ '/favicon.svg' | url }} />
<link rel="shortcut icon" href={{ '/favicon.ico' | url }} />
<link rel="apple-touch-icon" sizes="180x180" href={{ '/apple-touch-icon.png' | url }} />
<link rel="manifest" href="{{ '/site.webmanifest' | url }}" />
