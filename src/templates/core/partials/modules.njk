{#
  Renders a modules array.
  Requires: modules (array), _locale (string)

  Dispatch is purely file-based: for each module, looks up
  components/modules/{_type}.njk — customer-overridable, ignore missing.
  Core built-ins live in components/modules/ and can be overridden per project.
  Custom module types: drop src/_includes/components/modules/{type}.njk.
#}
{% for module in modules %}
  {%- set _isFirstModule = loop.first -%}
  <div class="module module--{{ module._type }}">
    {%- include "components/modules/" + module._type + ".njk" ignore missing -%}
  </div>
{% endfor %}
