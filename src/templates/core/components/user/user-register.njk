{%- set _locale = page.lang or coreConfig.defaultLocale -%}
<article class="static-page user-registration">
  {% block page_header %}<h1>{{ 'staticPages.userRegistration.title' | trans }}</h1>{% endblock %}
  {% block page_info %}<p>{{ 'staticPages.userRegistration.info' | trans }}</p>{% endblock %}

  {% block page_before_form %}{% endblock %}

  {% block page_content %}
  <div data-user-register
    data-api="/api/user/register"
    data-locale="{{ _locale }}"
    data-fields="{{ coreConfig.features.users.registrationFields | join(',') }}"
    data-t-error-email="{{ 'forms.fields.email.errorMessage' | trans }}"
    data-t-error-password="{{ 'forms.fields.password.errorMessage' | trans }}"
    data-t-error-prename="{{ 'forms.fields.prename.errorMessage' | trans }}"
    data-t-error-lastname="{{ 'forms.fields.lastname.errorMessage' | trans }}"
    data-t-error-line1="{{ 'forms.fields.street.errorMessage' | trans }}"
    data-t-error-zip="{{ 'forms.fields.zip.errorMessage' | trans }}"
    data-t-error-city="{{ 'forms.fields.city.errorMessage' | trans }}"
    data-t-error-country="{{ 'forms.fields.country.errorMessage' | trans }}"
    data-t-error-captcha="{{ 'forms.fields.captcha.errorMessage' | trans }}"
    data-t-error-service="{{ 'checkout.serviceError' | trans }}"
  >
    <form class="user-form" novalidate>
      <div class="user-form__basics">
        <div class="user-form__field">
          <label for="register-email">{{ 'forms.fields.email.label' | trans }}</label>
          <input type="email" id="register-email" name="email" required autocomplete="email">
          <span class="user-form__field-error" data-field-error="email"></span>
        </div>

        <div class="user-form__field" data-register-field="prename" hidden>
          <label for="register-prename">{{ 'forms.fields.prename.label' | trans }}</label>
          <input type="text" id="register-prename" name="prename" autocomplete="given-name">
          <span class="user-form__field-error" data-field-error="prename"></span>
        </div>

        <div class="user-form__field" data-register-field="lastname" hidden>
          <label for="register-lastname">{{ 'forms.fields.lastname.label' | trans }}</label>
          <input type="text" id="register-lastname" name="lastname" autocomplete="family-name">
          <span class="user-form__field-error" data-field-error="lastname"></span>
        </div>

        <div class="user-form__field" data-register-field="phone" hidden>
          <label for="register-phone">{{ 'forms.fields.phone.label' | trans }}</label>
          <input type="tel" id="register-phone" name="phone" autocomplete="tel">
          <span class="user-form__field-error" data-field-error="phone"></span>
        </div>
      </div>

      <div class="user-form__address" data-register-field="address" hidden>
        <div class="user-form__field">
          <label for="register-line1">{{ 'forms.fields.street.label' | trans }}</label>
          <input type="text" id="register-line1" name="line1" autocomplete="address-line1">
          <span class="user-form__field-error" data-field-error="line1"></span>
        </div>

        <div class="user-form__field">
          <label for="register-line2">{{ 'forms.fields.line2.label' | trans }}</label>
          <input type="text" id="register-line2" name="line2" autocomplete="address-line2">
          <span class="user-form__field-error" data-field-error="line2"></span>
        </div>

        <div class="user-form__field">
          <label for="register-zip">{{ 'forms.fields.zip.label' | trans }}</label>
          <input type="text" id="register-zip" name="zip" autocomplete="postal-code">
          <span class="user-form__field-error" data-field-error="zip"></span>
        </div>

        <div class="user-form__field">
          <label for="register-city">{{ 'forms.fields.city.label' | trans }}</label>
          <input type="text" id="register-city" name="city" autocomplete="address-level2">
          <span class="user-form__field-error" data-field-error="city"></span>
        </div>

        <div class="user-form__field">
          <label for="register-state">{{ 'forms.fields.state.label' | trans }}</label>
          <input type="text" id="register-state" name="state" autocomplete="address-level1">
          <span class="user-form__field-error" data-field-error="state"></span>
        </div>

        <div class="user-form__field">
          <label for="register-country">{{ 'forms.fields.country.label' | trans }}</label>
          <select id="register-country" name="country" autocomplete="country">
            <option value="">{{ 'forms.fields.country.none' | trans }}</option>
            {%- for c in _locale | countryList %}
            <option value="{{ c.code }}">{{ c.name }}</option>
            {%- endfor %}
          </select>
          <span class="user-form__field-error" data-field-error="country"></span>
        </div>
      </div>

      <div>
        <div class="user-form__field">
          <label for="register-password">{{ 'forms.fields.password.label' | trans }}</label>
          <input type="password" id="register-password" name="password" required autocomplete="new-password">
          <span class="user-form__field-error" data-field-error="password"></span>
        </div>
      </div>

      <div class="user-form__newsletter" data-register-field="newsletter" hidden>
        <label class="user-form__checkbox">
          <input type="checkbox" name="newsletter">
          {{ 'forms.fields.registerForNewsletter.label' | trans }}
        </label>
        {% block newsletter_privacy_notice %}
        <p class="user-form__newsletter-notice">{{ 'forms.fields.registerForNewsletter.privacyNotice' | trans({url: cms[_locale].privacyUrl}) | safe }}</p>
        {% endblock %}
      </div>

      {%- if coreConfig.captchaSiteKey %}
      <div class="user-form__captcha h-captcha" data-sitekey="{{ coreConfig.captchaSiteKey }}"></div>
      {%- endif %}

      <div class="user-form__error" role="alert" hidden data-form-error></div>

      <div class="user-form__submit">
        <button type="submit" class="btn">
          <span data-submit-text>{{ 'forms.userRegistration.submit.text' | trans }}</span>
          <span data-submit-loading hidden>{{ 'forms.userRegistration.submit.loadingText' | trans }}</span>
        </button>
      </div>
    </form>

    {% block page_login %}
      <a href="/{{ _locale }}/{{ coreConfig.userPaths[_locale].userLogin }}/">
        {{ 'staticPages.userLogin.title' | trans }}
      </a>
    {% endblock %}
  </div>
  {% endblock %}

  {% block page_after_form %}{% endblock %}

</article>

{%- if coreConfig.captchaSiteKey %}
<script src="https://js.hcaptcha.com/1/api.js" async defer></script>
{%- endif %}
