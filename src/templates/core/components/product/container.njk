{% from "macros/product.njk" import addToCartButton, productPrice, productStatus, qtyControl, productSiblings,
  productWineDetails, productBundleItems, productOptions,
  productCategories, productManufacturers %}

<article class="product" data-product-id="{{ product._id }}" data-kind="{{ product.kind }}" data-status="{{ product.status }}">

  <figure class="product__image">
    {% if product.image %}
      {% image product.image, imageSizes.product, { loading: "eager", fetchpriority: "high" } %}
    {% else %}
      {% include "overridable/product/placeholder.njk" %}
    {% endif %}
  </figure>

  <div class="product__body">
    <header class="product__header">
      <h1 class="product__title">{{ product.title }}</h1>
      {%- if product.sku %}
        <p class="product__sku">{{ product.sku }}</p>
      {%- endif %}
    </header>

    {{ productSiblings(product) }}

    <div class="product__purchase">
      {{ productPrice(product) }}

      {% block product_cart_control %}
      {%- if coreConfig.features.shop.checkout -%}
        <p class="product__tax-info">{{ 'product.taxShippingInfoText' | trans }}</p>
        
        <div class="product__actions" data-product-actions>
        {%- if product.status == "active" %}
          {{ qtyControl(locale=product.locale) }}
          {{ addToCartButton(product, label=('product.cartButton.addToCartShort' | trans), imageSize=imageSizes.cart) }}
        {%- else %}
          {{ productStatus(product) }}
        {%- endif %}
        </div>
      {%- endif -%}
      {% endblock %}
    </div>

    {%- if product.kind == "wine" and product.wine %}
      {{ productWineDetails(product) }}
    {%- endif %}

    {%- if product.kind == "bundle" %}
      {{ productBundleItems(product) }}
    {%- endif %}

    {%- if product.kind == "physical" or product.kind == "digital" %}
      {{ productOptions(product) }}
    {%- endif %}

    {{ productCategories(product) }}
    {{ productManufacturers(product) }}

  </div>

</article>
