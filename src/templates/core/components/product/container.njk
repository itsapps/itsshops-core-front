{% from "macros/product.njk" import productPrice, productStatus, productSiblings,
  productWineDetails, productBundleItems, productOptions,
  productCategories, productManufacturers %}

<article class="product" data-product-id="{{ product._id }}" data-kind="{{ product.kind }}" data-status="{{ product.status }}">

  <figure class="product-gallery">
    {% if product.image %}
      {% image product.image, imageSizes.product, { loading: "eager", fetchpriority: "high" } %}
    {% else %}
      {% include "components/product/placeholder.njk" %}
    {% endif %}
  </figure>

  <div class="product-body">

    <header class="product-header">
      {{ productStatus(product, class="product-status") }}
      <h1 class="product-title">{{ product.title }}</h1>
      {%- if product.sku %}
        <p class="product-sku">{{ product.sku }}</p>
      {%- endif %}
    </header>

    {{ productSiblings(product, class="product-siblings") }}

    <div class="product-purchase">
      {{ productPrice(product, class="product-price") }}
      <p class="product-tax-info">{{ 'product.taxShippingInfoText' | trans }}</p>
      <div class="product-actions" data-product-actions>
        {%- if product.status == "active" %}
          <div class="product-qty-control" data-qty-control>
            <button type="button" class="product-qty-control__btn" data-qty-decrease aria-label="{{ 'cart.counter.decreaseQuantity' | trans }}">−</button>
            <span class="product-qty-control__value" data-qty-value aria-live="polite">1</span>
            <button type="button" class="product-qty-control__btn" data-qty-increase aria-label="{{ 'cart.counter.increaseQuantity' | trans }}">+</button>
          </div>
          <button
            type="button"
            class="product-add-to-cart"
            data-add-to-cart
            data-product-id="{{ product._id }}"
            data-sku="{{ product.sku or '' }}"
            data-price="{{ product.price }}"
            data-title="{{ product.title }}"
            data-url="{{ product.url }}"
            {%- if product.image %} data-image="{{ product.image | imageSizeUrl(imageSizes.thumb) }}"{% endif %}
          >{{ 'product.cartButton.addToCart' | trans }}</button>
        {%- elif product.status == "comingSoon" %}
          <p class="product-unavailable">{{ 'product.states.comingSoon' | trans }}</p>
        {%- elif product.status == "soldOut" %}
          <p class="product-unavailable">{{ 'product.states.soldOut' | trans }}</p>
        {%- endif %}
      </div>
    </div>

    {%- if product.kind == "wine" and product.wine %}
      {{ productWineDetails(product, class="product-wine-details") }}
    {%- endif %}

    {%- if product.kind == "bundle" %}
      {{ productBundleItems(product, class="product-bundle") }}
    {%- endif %}

    {%- if product.kind == "physical" or product.kind == "digital" %}
      {{ productOptions(product, class="product-options") }}
    {%- endif %}

    {{ productCategories(product, class="product-categories") }}
    {{ productManufacturers(product, class="product-manufacturers") }}

  </div>

</article>
