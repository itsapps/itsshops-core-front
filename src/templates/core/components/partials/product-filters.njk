{#
  Product filter bar.
  Expects: filterGroups (array of FilterGroup), activeFilterKeys (array of group keys to show)
  activeFilterKeys: subset of filterGroups to render. If empty/undefined, renders all.
#}
{%- set _groups = [] -%}
{%- for group in filterGroups -%}
  {%- if not activeFilterKeys or activeFilterKeys.length == 0 or group.key in activeFilterKeys -%}
    {%- set _groups = (_groups.push(group), _groups) -%}
  {%- endif -%}
{%- endfor -%}

{% if _groups.length %}
  <div class="product-filters" data-product-filters data-t-results="{{ 'filters.results' | trans }}">
    {% for group in _groups %}
      <fieldset class="product-filters__group" data-filter-group="{{ group.key }}">
        <legend class="product-filters__label">{{ group.label }}</legend>
        <div class="product-filters__options">
          {% for val in group.values %}
            <label class="product-filters__option">
              <input
                type="checkbox"
                class="product-filters__checkbox"
                data-filter-key="{{ group.key }}"
                data-filter-value="{{ val.value }}"
              >
              <span>{{ val.label }}</span>
            </label>
          {% endfor %}
        </div>
      </fieldset>
    {% endfor %}
    <button type="button" class="product-filters__reset" data-filter-reset hidden>
      {{ "filters.reset" | trans }}
    </button>
    <p class="sr-only" aria-live="polite" aria-atomic="true" data-filter-count></p>
  </div>
{% endif %}
