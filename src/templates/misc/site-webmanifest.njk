---
permalink: /site.webmanifest
eleventyExcludeFromCollections: true
excludeFromSitemap: true
---
{%- set _settings = cms[coreConfig.defaultLocale].settings -%}
{
  "name": "{{ _settings.siteTitle | stegaClean }}",
  "short_name": "{{ _settings.siteTitle | stegaClean }}",
  "start_url": "{{ coreConfig.baseUrl }}/{{ coreConfig.defaultLocale }}/",
  "icons": [
    {
      "src": "/web-app-manifest-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "/web-app-manifest-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "theme_color": "{{ coreConfig.manifest.themeColor }}",
  "background_color": "{{ coreConfig.manifest.themeBgColor }}",
  "display": "standalone"
}
