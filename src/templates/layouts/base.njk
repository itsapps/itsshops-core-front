<!doctype html>
<html lang="{{ product.locale or category.locale or cmsPage.locale or defaultLocale }}">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="ie=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    {% block seo %}
      {%- set _item = product or category or cmsPage -%}
      {%- set _seo = _item.seo or {} -%}
      {%- set _seoTitle = _seo.metaTitle or _item.title or title -%}
      {%- set _seoDesc  = _seo.metaDescription or description -%}
      {%- set _shareImage = _seo.shareImage or _item.image -%}
      <title>{{ _seoTitle }}</title>
      {% if _seoDesc %}<meta name="description" content="{{ _seoDesc }}" />{% endif %}
      {% if _seo.keywords %}<meta name="keywords" content="{{ _seo.keywords }}" />{% endif %}
      <!-- Open Graph -->
      <meta property="og:type" content="website" />
      <meta property="og:title" content="{{ _seo.shareTitle or _seoTitle }}" />
      {% if _seo.shareDescription or _seoDesc %}
        <meta property="og:description" content="{{ _seo.shareDescription or _seoDesc }}" />
      {% endif %}
      {% if _shareImage %}
        <meta property="og:image" content="{{ _shareImage | imageUrl(1200) }}" />
      {% endif %}
    {% endblock %}

    {% block styles %}
      <link rel="stylesheet" href="/styles/index.css" />
    {% endblock %}

    {% block head %}{% endblock %}
  </head>

  <body>
    {% block header %}{% endblock %}

    <main id="main">
      {% block main %}
        {{ content | safe }}
      {% endblock %}
    </main>

    {% block footer %}{% endblock %}

    {% block scripts %}{% endblock %}

    {% if isPreview %}
      {% include "core/partials/visual-editing.njk" %}
    {% endif %}
  </body>
</html>
