<!doctype html>
<html lang="{{ page.lang }}">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="X-UA-Compatible" content="ie=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    {% block seo %}
      {%- set _item = product or category or cmsPage -%}
      {%- set _seo = _item.seo or {} -%}
      {%- set _seoTitle = _seo.metaTitle or _item.title or title -%}
      {%- set _seoDesc  = _seo.metaDescription or description -%}
      {%- set _shareImage = _seo.shareImage or _item.image -%}
      <title>{{ _seoTitle | stegaClean }}</title>
      {% if _seoDesc %}<meta name="description" content="{{ _seoDesc | stegaClean }}" />{% endif %}
      {% if _seo.keywords %}<meta name="keywords" content="{{ _seo.keywords | stegaClean }}" />{% endif %}
      <meta property="og:type" content="website" />
      <meta property="og:title" content="{{ (_seo.shareTitle or _seoTitle) | stegaClean }}" />
      {% if _seo.shareDescription or _seoDesc %}
        <meta property="og:description" content="{{ (_seo.shareDescription or _seoDesc) | stegaClean }}" />
      {% endif %}
      {% if _shareImage %}
        <meta property="og:image" content="{{ _shareImage | imageUrl(1200) }}" />
      {% endif %}
    {% endblock %}

    {% if coreConfig.buildMode == 'normal' %}
      {% include "core/head/schemas.njk" %}
      {% include "core/head/preloads.njk" %}
    {% endif %}

    {% block styles %}
      {% include "core/head/css.njk" %}
    {% endblock %}

    {% include "core/head/favicons.njk" %}

    {% block head %}{% endblock %}
  </head>

  <body>
    {% include "core/partials/dev-nav.njk" %}

    {% block header %}
      {%- include "components/header.njk" -%}
    {% endblock %}

    <main id="main">
      {% block main %}
        {{ content | safe }}
      {% endblock %}
    </main>

    {% block footer %}
      {%- include "components/footer.njk" -%}
    {% endblock %}

    {% block scripts %}{% endblock %}

    {% if coreConfig.preview.enabled %}
      {% include "core/partials/visual-editing.njk" %}
    {% endif %}
  </body>
</html>
