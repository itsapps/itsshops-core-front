{# ─── Product macros ──────────────────────────────────────────────────────────
 #
 # Usage:
 #   {% from "macros/product.njk" import productPrice, productStatus,
 #      productSiblings, productWineDetails, productBundleItems,
 #      productOptions, productCategories, productManufacturers,
 #      qtyControl, addToCartButton %}
 #
 #}

{# ─── Price ───────────────────────────────────────────────────────────────────
 # Renders price + optional compare-at (strikethrough) price.
 #
 # @param product   ResolvedVariant
 # @param class     optional CSS class on the wrapper (default: "product-price")
 #}
{% macro productPrice(product, class="product-price") %}
<div class="{{ class }}">
  {%- if product.compareAtPrice %}
    <s class="{{ class }}__compare">
      <span class="sr-only">{{ 'product.price.was' | trans({ lng: product.locale }) }}: </span>{{ product.compareAtPrice | formatPrice(product.locale) }}
    </s>
  {%- endif %}
  <span class="{{ class }}__amount">{{ product.price | formatPrice(product.locale) }}</span>
</div>
{% endmacro %}


{# ─── Status ──────────────────────────────────────────────────────────────────
 # Renders a status badge when the product is not active.
 #
 # @param product   ResolvedVariant
 # @param class     optional CSS class (default: "product-status")
 #}
{% macro productStatus(product, class="product-status") %}
{%- if product.status != "active" %}
  <span class="{{ class }} {{ class }}--{{ product.status }}">
    {{- ('product.states.' + product.status) | trans(product.locale) -}}
  </span>
{%- endif %}
{% endmacro %}


{# ─── Siblings / variant switcher ─────────────────────────────────────────────
 # Renders a nav of sibling variants. The current variant is marked aria-current.
 # Unavailable siblings get a modifier class.
 #
 # @param product   ResolvedVariant  (current variant)
 # @param class     optional CSS class (default: "product-siblings")
 #}
{% macro productSiblings(product, class="product-siblings") %}
{%- if product.siblings.length %}
  <nav class="{{ class }}" aria-label="{{ 'product.ariaVariants' | trans({ lng: product.locale }) }}">
    <a
      class="{{ class }}__item {{ class }}__item--current"
      href="{{ product.url }}"
      aria-current="page"
    >{{ product.label }}</a>
    {%- for sibling in product.siblings %}
      <a
        class="{{ class }}__item{% if sibling.status != 'active' %} {{ class }}__item--unavailable{% endif %}"
        href="{{ sibling.url }}"
      >{{ sibling.label }}</a>
    {%- endfor %}
  </nav>
{%- endif %}
{% endmacro %}


{# ─── Options ─────────────────────────────────────────────────────────────────
 # Renders option names for physical/digital products.
 #
 # @param product   ResolvedVariant
 # @param class     optional CSS class (default: "product-options")
 #}
{% macro productOptions(product, class="product-options") %}
{%- if product.options.length %}
  <ul class="{{ class }}">
    {%- for option in product.options %}
      <li class="{{ class }}__item">{{ option.name }}</li>
    {%- endfor %}
  </ul>
{%- endif %}
{% endmacro %}


{# ─── Bundle items ────────────────────────────────────────────────────────────
 # Renders the list of items in a bundle variant.
 #
 # @param product   ResolvedVariant
 # @param class     optional CSS class (default: "product-bundle")
 #}
{% macro productBundleItems(product, class="product-bundle") %}
{%- if product.bundleItems.length %}
  <ul class="{{ class }}">
    {%- for item in product.bundleItems %}
      <li class="{{ class }}__item">
        <span class="{{ class }}__qty">{{ item.quantity }}×</span>
        {%- if item.variant.url %}
          <a class="{{ class }}__link" href="{{ item.variant.url }}">{{ item.variant.title }}</a>
        {%- else %}
          <span class="{{ class }}__name">{{ item.variant.title }}</span>
        {%- endif %}
        {%- if item.variant.kind == "wine" and (item.variant.volume or item.variant.vintage) %}
          <span class="{{ class }}__meta">
            {%- if item.variant.volume %}{{ item.variant.volume | formatVolume }}{% endif %}
            {%- if item.variant.volume and item.variant.vintage %} · {% endif %}
            {%- if item.variant.vintage %}{{ item.variant.vintage }}{% endif -%}
          </span>
        {%- elif item.variant.options.length %}
          <span class="{{ class }}__meta">{{ item.variant.options | map('name') | join(', ') }}</span>
        {%- endif %}
      </li>
    {%- endfor %}
  </ul>
{%- endif %}
{% endmacro %}


{# ─── Categories ──────────────────────────────────────────────────────────────
 # Renders a list of category links.
 #
 # @param product   ResolvedVariant
 # @param class     optional CSS class (default: "product-categories")
 #}
{% macro productCategories(product, class="product-categories") %}
{%- if product.categories.length %}
  <ul class="{{ class }}">
    {%- for cat in product.categories %}
      <li class="{{ class }}__item">
        <a class="{{ class }}__link" href="{{ cat.url }}">{{ cat.title }}</a>
      </li>
    {%- endfor %}
  </ul>
{%- endif %}
{% endmacro %}


{# ─── Manufacturers ───────────────────────────────────────────────────────────
 # Renders a list of manufacturer names.
 #
 # @param product   ResolvedVariant
 # @param class     optional CSS class (default: "product-manufacturers")
 #}
{% macro productManufacturers(product, class="product-manufacturers") %}
{%- if product.manufacturers.length %}
  <ul class="{{ class }}">
    {%- for m in product.manufacturers %}
      <li class="{{ class }}__item">{{ m.name }}</li>
    {%- endfor %}
  </ul>
{%- endif %}
{% endmacro %}


{# ─── Quantity control ────────────────────────────────────────────────────────
 # Renders a quantity stepper (−/+) for add-to-cart forms.
 #
 # @param class     optional CSS class on the wrapper (default: "qty-control")
 #}
{% macro qtyControl(locale="", class="qty-control") %}
<div class="{{ class }}" data-qty-control
  data-t-decrease="{{ 'cart.counter.decreaseQuantity' | trans({ lng: locale }) }}"
  data-t-increase="{{ 'cart.counter.increaseQuantity' | trans({ lng: locale }) }}"
  data-t-quantity="{{ 'cart.counter.quantity' | trans({ lng: locale }) }}"
>
  <button type="button" class="{{ class }}__btn" data-qty-decrease aria-label="{{ 'cart.counter.decreaseQuantity' | trans({ lng: locale }) }}">−</button>
  <output class="{{ class }}__value" data-qty-value>1</output>
  <button type="button" class="{{ class }}__btn" data-qty-increase aria-label="{{ 'cart.counter.increaseQuantity' | trans({ lng: locale }) }}">+</button>
</div>
{% endmacro %}


{# ─── Add to cart button ─────────────────────────────────────────────────────
 # Renders an add-to-cart button with all required data attributes.
 # Automatically builds a subtitle from wine data when available.
 #
 # @param product   ResolvedVariant
 # @param class     optional CSS class (default: "add-to-cart")
 # @param label     optional button label (default: translation key)
 # @param subtitle  optional explicit subtitle (overrides auto-generated wine subtitle)
 # @param imageSize image size preset for thumb (required — pass imageSizes.thumb or similar)
 #}
{% macro addToCartButton(product, class="add-to-cart", label="", subtitle="", imageSize=null, locale="") %}
{%- set _locale = locale if locale else product.locale -%}
{%- set _imageSize = imageSize -%}
{%- set _label = label if label else ('product.cartButton.addToCart' | trans(_locale)) -%}
{%- set _subtitle = subtitle -%}
{%- if not _subtitle -%}
  {%- set _parts = [] -%}
  {%- if product.kind == "wine" and product.wine -%}
    {%- if product.wine.volume %}{%- set _parts = _parts.concat([product.wine.volume | formatVolume]) %}{% endif -%}
    {%- if product.wine.vintage %}{%- set _parts = _parts.concat([product.wine.vintage]) %}{% endif -%}
  {%- elif product.kind == "bundle" and product.bundleItems and product.bundleItems.length -%}
    {%- for item in product.bundleItems %}{%- set _parts = _parts.concat([item.quantity + '× ' + item.variant.title]) %}{% endfor -%}
  {%- elif product.options and product.options.length -%}
    {%- set _parts = _parts.concat([product.options | map('name') | join(', ')]) -%}
  {%- endif -%}
  {%- set _subtitle = _parts | join(', ') -%}
{%- endif -%}
<button
  type="button"
  class="{{ class }}"
  aria-label="{{ _label }}: {{ product.title }}"
  data-add-to-cart
  data-aria-add-template="{{ 'product.cartButton.ariaAddToCart' | trans({ lng: _locale }) }}"
  data-product-id="{{ product._id }}"
  data-sku="{{ product.sku or '' }}"
  data-price="{{ product.price }}"
  data-title="{{ product.title }}"
  {%- if _subtitle %} data-subtitle="{{ _subtitle }}"{% endif %}
  data-url="{{ product.url }}"
  data-added-to-cart="{{ 'product.cartButton.addedToCart' | trans({ lng: _locale }) }}"
  {%- if product.image and _imageSize %} data-image="{{ product.image | imageSizeUrl(_imageSize) }}"{% endif %}
>{{ _label }}</button>
{% endmacro %}


{# ─── Wine details ────────────────────────────────────────────────────────────
 # Renders a <dl> of wine facts from Vinofact data.
 # Only renders rows for fields that are present on the wine object.
 #
 # @param product   ResolvedVariant  (must be kind == "wine")
 # @param class     optional CSS class (default: "wine-details")
 #}
{% macro productWineDetails(product, class="wine-details") %}
{%- if product.kind == "wine" and product.wine %}
  {%- set wine = product.wine %}
  <dl class="{{ class }}">

    {%- if wine.volume %}
      <div class="{{ class }}__row">
        <dt class="{{ class }}__label">{{ 'product.wine.volume' | trans({ lng: product.locale }) }}</dt>
        <dd class="{{ class }}__value">{{ wine.volume | formatVolume }}</dd>
      </div>
    {%- endif %}

    {%- if wine.vintage %}
      <div class="{{ class }}__row">
        <dt class="{{ class }}__label">{{ 'product.wine.vintage' | trans({ lng: product.locale }) }}</dt>
        <dd class="{{ class }}__value">{{ wine.vintage }}</dd>
      </div>
    {%- endif %}

    {%- if wine.color %}
      <div class="{{ class }}__row">
        <dt class="{{ class }}__label">{{ 'product.wine.color' | trans({ lng: product.locale }) }}</dt>
        <dd class="{{ class }}__value">{{ wine.color }}</dd>
      </div>
    {%- endif %}

    {%- if wine.type %}
      <div class="{{ class }}__row">
        <dt class="{{ class }}__label">{{ 'product.wine.type' | trans({ lng: product.locale }) }}</dt>
        <dd class="{{ class }}__value">{{ wine.type }}</dd>
      </div>
    {%- endif %}

    {%- if wine.alcohol %}
      <div class="{{ class }}__row">
        <dt class="{{ class }}__label">{{ 'product.wine.alcohol' | trans({ lng: product.locale }) }}</dt>
        <dd class="{{ class }}__value">{{ wine.alcohol }}%</dd>
      </div>
    {%- endif %}

    {%- if wine.tartaricAcid %}
      <div class="{{ class }}__row">
        <dt class="{{ class }}__label">{{ 'product.wine.tartaricAcid' | trans({ lng: product.locale }) }}</dt>
        <dd class="{{ class }}__value">{{ wine.tartaricAcid }} g/l</dd>
      </div>
    {%- endif %}

    {%- if wine.freeSulfur %}
      <div class="{{ class }}__row">
        <dt class="{{ class }}__label">{{ 'product.wine.freeSulfur' | trans({ lng: product.locale }) }}</dt>
        <dd class="{{ class }}__value">{{ wine.freeSulfur }} mg/l</dd>
      </div>
    {%- endif %}

    {%- if wine.totalSulfur %}
      <div class="{{ class }}__row">
        <dt class="{{ class }}__label">{{ 'product.wine.totalSulfur' | trans({ lng: product.locale }) }}</dt>
        <dd class="{{ class }}__value">{{ wine.totalSulfur }} mg/l</dd>
      </div>
    {%- endif %}

    {%- if wine.phValue %}
      <div class="{{ class }}__row">
        <dt class="{{ class }}__label">{{ 'product.wine.phValue' | trans({ lng: product.locale }) }}</dt>
        <dd class="{{ class }}__value">{{ wine.phValue }}</dd>
      </div>
    {%- endif %}

    {%- if wine.histamine %}
      <div class="{{ class }}__row">
        <dt class="{{ class }}__label">{{ 'product.wine.histamine' | trans({ lng: product.locale }) }}</dt>
        <dd class="{{ class }}__value">{{ wine.histamine }} mg/l</dd>
      </div>
    {%- endif %}

    {%- if wine.varietals and wine.varietals.length %}
      <div class="{{ class }}__row">
        <dt class="{{ class }}__label">{{ 'product.wine.varietals' | trans({ lng: product.locale }) }}</dt>
        <dd class="{{ class }}__value">{{ wine.varietals | map('name') | join(', ') }}</dd>
      </div>
    {%- endif %}

    {%- if wine.classifications and wine.classifications.length %}
      <div class="{{ class }}__row">
        <dt class="{{ class }}__label">{{ 'product.wine.classifications' | trans({ lng: product.locale }) }}</dt>
        <dd class="{{ class }}__value">{{ wine.classifications | map('name') | join(', ') }}</dd>
      </div>
    {%- endif %}

    {%- if wine.terroir and wine.terroir.name %}
      <div class="{{ class }}__row">
        <dt class="{{ class }}__label">{{ 'product.wine.terroir' | trans({ lng: product.locale }) }}</dt>
        <dd class="{{ class }}__value">{{ wine.terroir.name }}</dd>
      </div>
    {%- endif %}

    {%- if wine.terroir and wine.terroir.soils and wine.terroir.soils.length %}
      <div class="{{ class }}__row">
        <dt class="{{ class }}__label">{{ 'product.wine.soils' | trans({ lng: product.locale }) }}</dt>
        <dd class="{{ class }}__value">{{ wine.terroir.soils | map('name') | join(', ') }}</dd>
      </div>
    {%- endif %}

    {%- if wine.awards and wine.awards.length %}
      <div class="{{ class }}__row">
        <dt class="{{ class }}__label">{{ 'product.wine.awards' | trans({ lng: product.locale }) }}</dt>
        <dd class="{{ class }}__value">
          <ul class="{{ class }}__awards">
            {%- for award in wine.awards %}
              <li>{{ award.name }}{% if award.value %}: {{ award.value }}{% endif %}</li>
            {%- endfor %}
          </ul>
        </dd>
      </div>
    {%- endif %}

  </dl>
{%- endif %}
{% endmacro %}
