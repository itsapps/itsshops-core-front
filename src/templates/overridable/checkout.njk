{%- set _locale = page.lang or coreConfig.defaultLocale -%}
<article class="checkout region wrapper">
  <h1>{{ 'staticPages.checkout.title' | trans }}</h1>

  <div
    id="checkout"
    data-checkout
    data-checkout-api="/api/payment/create"
    data-stripe-key="{{ coreConfig.stripe.publishableApiKey }}"
    data-return-url="{{ coreConfig.baseUrl }}{{ cms[_locale].checkoutUrl }}{{ coreConfig.resolvedPermalinks[_locale].orderThanks }}/"
    data-currency="{{ coreConfig.units.price.currency | default('EUR') | upper }}"
    {% if coreConfig.units.price.currencyLabel %}data-currency-label="{{ coreConfig.units.price.currencyLabel }}"{% endif %}
    data-t-subtotal="{{ 'checkout.subtotal' | trans }}"
    data-t-shipping="{{ 'checkout.shipping' | trans }}"
    data-t-total="{{ 'checkout.total' | trans }}"
    data-t-free-shipping="{{ 'checkout.freeShipping' | trans }}"
    data-t-cart-empty="{{ 'checkout.cartEmpty' | trans }}"
    data-t-error="{{ 'checkout.error' | trans }}"
    data-t-service-error="{{ 'checkout.serviceError' | trans }}"
    data-t-items-unavailable="{{ 'checkout.itemsUnavailable' | trans }}"
    data-t-available="{{ 'checkout.available' | trans }}"
    data-t-error-email="{{ 'forms.fields.email.errorMessage' | trans }}"
    data-t-error-prename="{{ 'forms.fields.prename.errorMessage' | trans }}"
    data-t-error-lastname="{{ 'forms.fields.lastname.errorMessage' | trans }}"
    data-t-error-street="{{ 'forms.fields.street.errorMessage' | trans }}"
    data-t-error-city="{{ 'forms.fields.city.errorMessage' | trans }}"
    data-t-error-zip="{{ 'forms.fields.zip.errorMessage' | trans }}"
    data-t-error-country="{{ 'forms.fields.country.errorMessage' | trans }}"
  >
    {# Loading state #}
    <div data-checkout-loading class="checkout__loading" aria-live="polite">
      {{ 'checkout.loading' | trans }}
    </div>

    {# Validation error #}
    <div data-checkout-error-global class="checkout__error" role="alert" hidden></div>

    {# Service error (IO/server) — shown with requestId for support #}
    <div data-checkout-service-error class="checkout__service-error" role="alert" hidden>
      <p>{{ 'checkout.serviceError' | trans }}</p>
      <p class="checkout__request-id">Request ID: <code data-request-id></code></p>
      {% if cms[_locale].settings.supportEmail %}
        <a href="mailto:{{ cms[_locale].settings.supportEmail }}?subject={{ 'checkout.serviceErrorContact' | trans | urlencode }}&amp;body=RequestId:" class="checkout__service-error-link">
          {{ 'checkout.serviceErrorContact' | trans }}
        </a>
      {% endif %}
    </div>

    <form data-checkout-form class="checkout__form" novalidate>
      <div class="checkout__columns">
        {# ── Left column: form fields ──────────────────────────────────── #}
        <div class="checkout__fields">

          {# Contact #}
          <fieldset class="checkout__section">
            <legend>{{ 'checkout.sections.contact' | trans }}</legend>
            <div class="checkout__field">
              <label for="checkout-email">{{ 'forms.fields.email.label' | trans }}</label>
              <input type="email" id="checkout-email" name="contactEmail" required autocomplete="email">
              <span data-checkout-error="contactEmail" class="checkout__field-error"></span>
            </div>
          </fieldset>

          {# Shipping address #}
          <fieldset class="checkout__section">
            <legend>{{ 'checkout.sections.delivery' | trans }}</legend>
            <div class="checkout__field-row">
              <div class="checkout__field">
                <label for="checkout-prename">{{ 'forms.fields.prename.label' | trans }}</label>
                <input type="text" id="checkout-prename" name="shipping.prename" required autocomplete="given-name">
                <span data-checkout-error="shipping.prename" class="checkout__field-error"></span>
              </div>
              <div class="checkout__field">
                <label for="checkout-lastname">{{ 'forms.fields.lastname.label' | trans }}</label>
                <input type="text" id="checkout-lastname" name="shipping.lastname" required autocomplete="family-name">
                <span data-checkout-error="shipping.lastname" class="checkout__field-error"></span>
              </div>
            </div>
            <div class="checkout__field">
              <input type="hidden" name="shipping.name" value="">
              <label for="checkout-line1">{{ 'forms.fields.street.label' | trans }}</label>
              <input type="text" id="checkout-line1" name="shipping.line1" required autocomplete="address-line1">
              <span data-checkout-error="shipping.line1" class="checkout__field-error"></span>
            </div>
            <div class="checkout__field-row">
              <div class="checkout__field checkout__field--zip">
                <label for="checkout-zip">{{ 'forms.fields.zip.label' | trans }}</label>
                <input type="text" id="checkout-zip" name="shipping.zip" required autocomplete="postal-code">
                <span data-checkout-error="shipping.zip" class="checkout__field-error"></span>
              </div>
              <div class="checkout__field">
                <label for="checkout-city">{{ 'forms.fields.city.label' | trans }}</label>
                <input type="text" id="checkout-city" name="shipping.city" required autocomplete="address-level2">
                <span data-checkout-error="shipping.city" class="checkout__field-error"></span>
              </div>
            </div>
            <div class="checkout__field">
              <label for="checkout-country">{{ 'forms.fields.country.label' | trans }}</label>
              <select id="checkout-country" name="shipping.country" data-checkout-country required autocomplete="country">
                <option value="">{{ 'forms.fields.country.none' | trans }}</option>
              </select>
              <span data-checkout-error="shipping.country" class="checkout__field-error"></span>
            </div>
          </fieldset>

          {# Billing toggle + address #}
          <fieldset class="checkout__section">
            <label class="checkout__checkbox">
              <input type="checkbox" data-checkout-same-billing checked>
              {{ 'forms.checkout.useShippingAsBilling' | trans }}
            </label>
            <div data-checkout-billing-fields class="checkout__billing" hidden>
              <legend>{{ 'checkout.sections.billing' | trans }}</legend>
              <div class="checkout__field-row">
                <div class="checkout__field">
                  <label for="checkout-billing-prename">{{ 'forms.fields.prename.label' | trans }}</label>
                  <input type="text" id="checkout-billing-prename" name="billing.prename" autocomplete="billing given-name">
                  <span data-checkout-error="billing.prename" class="checkout__field-error"></span>
                </div>
                <div class="checkout__field">
                  <label for="checkout-billing-lastname">{{ 'forms.fields.lastname.label' | trans }}</label>
                  <input type="text" id="checkout-billing-lastname" name="billing.lastname" autocomplete="billing family-name">
                  <span data-checkout-error="billing.lastname" class="checkout__field-error"></span>
                </div>
              </div>
              <div class="checkout__field">
                <input type="hidden" name="billing.name" value="">
                <label for="checkout-billing-line1">{{ 'forms.fields.street.label' | trans }}</label>
                <input type="text" id="checkout-billing-line1" name="billing.line1" autocomplete="billing address-line1">
                <span data-checkout-error="billing.line1" class="checkout__field-error"></span>
              </div>
              <div class="checkout__field-row">
                <div class="checkout__field checkout__field--zip">
                  <label for="checkout-billing-zip">{{ 'forms.fields.zip.label' | trans }}</label>
                  <input type="text" id="checkout-billing-zip" name="billing.zip" autocomplete="billing postal-code">
                  <span data-checkout-error="billing.zip" class="checkout__field-error"></span>
                </div>
                <div class="checkout__field">
                  <label for="checkout-billing-city">{{ 'forms.fields.city.label' | trans }}</label>
                  <input type="text" id="checkout-billing-city" name="billing.city" autocomplete="billing address-level2">
                  <span data-checkout-error="billing.city" class="checkout__field-error"></span>
                </div>
              </div>
              <div class="checkout__field">
                <label for="checkout-billing-country">{{ 'forms.fields.country.label' | trans }}</label>
                <select id="checkout-billing-country" name="billing.country" data-checkout-billing-country autocomplete="billing country">
                  <option value="">{{ 'forms.fields.country.none' | trans }}</option>
                </select>
                <span data-checkout-error="billing.country" class="checkout__field-error"></span>
              </div>
            </div>
          </fieldset>

          {# Shipping method #}
          <fieldset class="checkout__section">
            <legend>{{ 'checkout.sections.shippingMethod' | trans }}</legend>
            <div data-checkout-shipping class="checkout-shipping"></div>
          </fieldset>

          {# Payment #}
          <fieldset class="checkout__section">
            <legend>{{ 'checkout.sections.payment' | trans }}</legend>
            <div data-checkout-payment class="checkout-payment"></div>
          </fieldset>

          <button type="submit" data-checkout-submit class="checkout__submit btn">
            {{ 'forms.checkout.submit.text' | trans }}
          </button>
        </div>

        {# ── Right column: order summary ───────────────────────────────── #}
        <aside class="checkout__summary">
          <h2>{{ 'checkout.sections.summary' | trans }}</h2>
          <div data-checkout-items class="checkout-items"></div>
          <div data-checkout-totals class="checkout-totals"></div>
        </aside>
      </div>
    </form>
  </div>

  <template id="checkout-item-template">
    <div class="cart-item" data-cart-item>
      <img src="" alt="" class="cart-item__image" loading="lazy" data-slot="image">
      <div class="cart-item__body">
        <span class="cart-item__title" data-slot="title"></span>
        <span class="cart-item__subtitle" data-slot="subtitle" hidden></span>
        <div class="cart-item__row">
          <div class="cart-item__qty" data-qty-control>
            <button type="button" class="cart-item__qty-btn" data-qty-decrease aria-label="{{ 'cart.counter.decreaseQuantity' | trans }}">−</button>
            <output class="cart-item__qty-count" data-qty-value aria-live="polite">1</output>
            <button type="button" class="cart-item__qty-btn" data-qty-increase aria-label="{{ 'cart.counter.increaseQuantity' | trans }}">+</button>
          </div>
          <span class="cart-item__price" data-slot="price"></span>
          <button type="button" class="cart-item__remove" data-cart-remove aria-label="{{ 'cart.ariaRemoveProduct' | trans }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </button>
        </div>
        <span class="cart-item__stock-note" data-slot="stock-note" aria-live="polite" hidden></span>
      </div>
    </div>
  </template>
</article>
