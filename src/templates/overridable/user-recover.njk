{%- set _locale = page.lang or coreConfig.defaultLocale -%}
<article class="region wrapper flow">
  <h1>{{ 'staticPages.userRecover.title' | trans }}</h1>
  <p>{{ 'staticPages.userRecover.info' | trans }}</p>

  <div data-user-recover
    data-api="/api/user/recover"
    data-locale="{{ _locale }}"
    data-t-error-email="{{ 'forms.fields.email.errorMessage' | trans }}"
  >
    <form class="user-form" novalidate>
      <div class="user-form__field">
        <label for="recover-email">{{ 'forms.fields.email.label' | trans }}</label>
        <input type="email" id="recover-email" name="email" required autocomplete="email">
        <span class="user-form__field-error" data-field-error="email"></span>
      </div>

      <div class="user-form__error" role="alert" hidden data-form-error></div>

      <button type="submit" class="btn">
        <span data-submit-text>{{ 'forms.userRecover.submit.text' | trans }}</span>
        <span data-submit-loading hidden>{{ 'forms.userRecover.submit.loadingText' | trans }}</span>
      </button>
    </form>

    <a href="/{{ _locale }}/{{ coreConfig.userPaths[_locale].userLogin }}/">
      {{ 'staticPages.userLogin.title' | trans }}
    </a>
  </div>
</article>
