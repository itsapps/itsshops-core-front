{%- set _locale = page.lang or coreConfig.defaultLocale -%}
<article class="region wrapper flow">
  <h1>{{ 'staticPages.userRegistration.title' | trans }}</h1>
  <p>{{ 'staticPages.userRegistration.info' | trans }}</p>

  <div data-user-register
    data-api="/api/user/register"
    data-locale="{{ _locale }}"
    data-fields="{{ coreConfig.features.users.registrationFields | join(',') }}"
    data-t-error-email="{{ 'forms.fields.email.errorMessage' | trans }}"
    data-t-error-password="{{ 'forms.fields.password.errorMessage' | trans }}"
    data-t-error-prename="{{ 'forms.fields.prename.errorMessage' | trans }}"
    data-t-error-lastname="{{ 'forms.fields.lastname.errorMessage' | trans }}"
  >
    <form class="user-form" novalidate>
      <div class="user-form__field">
        <label for="register-email">{{ 'forms.fields.email.label' | trans }}</label>
        <input type="email" id="register-email" name="email" required autocomplete="email">
        <span class="user-form__field-error" data-field-error="email"></span>
      </div>

      <div class="user-form__field" data-register-field="prename" hidden>
        <label for="register-prename">{{ 'forms.fields.prename.label' | trans }}</label>
        <input type="text" id="register-prename" name="prename" autocomplete="given-name">
        <span class="user-form__field-error" data-field-error="prename"></span>
      </div>

      <div class="user-form__field" data-register-field="lastname" hidden>
        <label for="register-lastname">{{ 'forms.fields.lastname.label' | trans }}</label>
        <input type="text" id="register-lastname" name="lastname" autocomplete="family-name">
        <span class="user-form__field-error" data-field-error="lastname"></span>
      </div>

      <div class="user-form__field" data-register-field="phone" hidden>
        <label for="register-phone">{{ 'forms.fields.phone.label' | trans }}</label>
        <input type="tel" id="register-phone" name="phone" autocomplete="tel">
        <span class="user-form__field-error" data-field-error="phone"></span>
      </div>

      <div class="user-form__field">
        <label for="register-password">{{ 'forms.fields.password.label' | trans }}</label>
        <input type="password" id="register-password" name="password" required autocomplete="new-password">
        <span class="user-form__field-error" data-field-error="password"></span>
      </div>

      <label class="user-form__checkbox" data-register-field="newsletter" hidden>
        <input type="checkbox" name="newsletter">
        {{ 'forms.fields.registerForNewsletter.label' | trans }}
      </label>

      <div class="user-form__error" role="alert" hidden data-form-error></div>

      <button type="submit" class="btn">
        <span data-submit-text>{{ 'forms.userRegistration.submit.text' | trans }}</span>
        <span data-submit-loading hidden>{{ 'forms.userRegistration.submit.loadingText' | trans }}</span>
      </button>
    </form>

    <a href="/{{ _locale }}/{{ coreConfig.userPaths[_locale].userLogin }}/">
      {{ 'staticPages.userLogin.title' | trans }}
    </a>
  </div>
</article>
