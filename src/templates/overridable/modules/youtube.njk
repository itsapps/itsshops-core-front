<div class="youtube-embed">
  {% if module.url %}
    <iframe
      src="{{ module.url }}"
      title="{{ module.title or 'YouTube video' | trans }}"
      frameborder="0"
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
      allowfullscreen
      loading="lazy"
    ></iframe>
  {% endif %}
</div>
